{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/contacto", "destination": "/Contacto/index.html" },
    { "source": "/mis-especialidades", "destination": "/mis-especialidades/index.html" },
    { "source": "/certificado-alura", "destination": "/mis-especialidades/certificado-alura-latam.html" }
  ],
  "redirects": [
    { "source": "/Contacto", "destination": "/contacto", "permanent": true },
    { "source": "/Mis especialidades", "destination": "/mis-especialidades", "permanent": true }
  ],
  "headers": [
    {
      "source": "(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
